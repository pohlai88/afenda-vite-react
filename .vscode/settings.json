{
  "yaml.schemas": {
    "https://json.schemastore.org/pnpm-workspace.json": "pnpm-workspace.yaml"
  },

  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  "eslint.enable": true,
  "eslint.useFlatConfig": true,

  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.quickSuggestions": {
      "strings": "on"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.quickSuggestions": {
      "strings": "on"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "css.lint.unknownAtRules": "ignore",

  "tailwindCSS.lint.suggestCanonicalClasses": "ignore",

  "tailwindCSS.experimental.configFile": {
    "apps/web/src/index.css": "apps/web/**",
    "packages/design-system/design-architecture/src/local.css": "packages/design-system/**"
  },

  "files.associations": {
    ".cursorignore": "ignore",
    "**/apps/web/src/index.css": "tailwindcss",
    "**/packages/design-system/design-architecture/src/**/*.css": "tailwindcss"
  },

  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.vite": true,
    "**/packages/vitest-config/_vitest-github": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.vite/**": true,
    "**/packages/vitest-config/_vitest-github/**": true
  },

  "vitest.rootConfig": "./vitest.config.ts",
  "vitest.configSearchPatternInclude": "{vitest.config.ts,apps/*/vite.config.ts,apps/*/vitest.config.ts,packages/*/vitest.config.ts}",
  "vitest.configSearchPatternExclude": "{**/node_modules/**,**/vendor/**,**/.*/**,**/archives/**,**/.legacy/**,**/.artifacts/**,**/*.d.ts,**/packages/vitest-config/_vitest-github/**}",
  "vitest.nodeEnv": {
    "VITEST_MAX_WORKERS": "50%",
    "VITEST_POOL": "forks"
  },

  "vitest.maximumConfigs": 9,

  "notebook.formatOnSave.enabled": true,
  "notebook.defaultFormatter": "esbenp.prettier-vscode"
}
