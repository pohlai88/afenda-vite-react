# Optional: Vercel Remote Cache for Turborepo (CI + local)
# https://turborepo.com/docs/core-concepts/remote-caching
#
# Create a token: https://vercel.com/account/tokens
# Team slug: Vercel dashboard → Team Settings → General → Team ID / slug
#
# GitHub Actions: set repository secret TURBO_TOKEN and variable TURBO_TEAM
# (see .github/workflows/ci.yml)
#
# TURBO_TOKEN=
# TURBO_TEAM=
