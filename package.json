{
  "name": "afenda-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:run": "turbo run test:run --concurrency=3",
    "test:ui": "turbo run test:ui --filter=@afenda/web",
    "test:coverage": "turbo run test:coverage",
    "build:analyze": "turbo run build:analyze --filter=@afenda/web",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "repo:guard": "tsx scripts/repo-integrity/run-repo-guard.ts",
    "repo:guard:ci": "tsx scripts/repo-integrity/run-repo-guard.ts --ci",
    "repo:guard:report": "tsx scripts/repo-integrity/run-repo-guard.ts --report",
    "tokens:check": "pnpm --filter @afenda/design-system run tokens:check",
    "icons:generate": "pnpm --filter @afenda/design-system run icons:generate",
    "icons:check": "pnpm --filter @afenda/design-system run icons:check",
    "check": "pnpm run script:check-governance && pnpm run script:check-app-surface && pnpm run script:generate-i18n-corpus && pnpm run script:generate-i18n-crossref-audit && pnpm run script:validate-i18n-policy && pnpm run script:i18n-check && pnpm run tokens:check && pnpm run lint && pnpm run typecheck && pnpm run test:run && pnpm run build",
    "preview": "turbo run preview",
    "script:inspect-vite-env": "pnpm --filter @afenda/web run inspect:vite-env",
    "script:inspect-node-runtime": "tsx scripts/inspect-node-runtime.ts",
    "script:generate-docs-readme": "tsx scripts/generate-docs-readme.ts",
    "script:check-governance": "pnpm run script:check-governance-registry && pnpm run script:check-governance-bindings && pnpm run script:run-governance-checks && pnpm run script:generate-governance-report && pnpm run script:generate-governance-register && pnpm run script:test-governance-honesty",
    "script:check-toolchain-runtime": "tsx scripts/check-toolchain-runtime.ts",
    "script:check-afenda-config": "tsx scripts/check-afenda-config.ts",
    "script:check-governance-registry": "tsx scripts/check-governance-registry.ts",
    "script:check-governance-bindings": "tsx scripts/check-governance-bindings.ts",
    "script:check-governance-waivers": "tsx scripts/check-governance-waivers.ts",
    "script:check-architecture-contracts": "tsx scripts/check-architecture-contracts.ts",
    "script:check-doc-governance": "tsx scripts/check-doc-governance.ts",
    "script:check-naming-convention": "tsx scripts/check-naming-convention.ts",
    "script:check-repo-guard": "tsx scripts/check-repo-guard.ts",
    "script:run-governance-checks": "tsx scripts/run-governance-checks.ts",
    "script:generate-governance-report": "tsx scripts/generate-governance-report.ts",
    "script:generate-governance-register": "tsx scripts/generate-governance-register.ts",
    "script:check-filesystem-governance": "tsx scripts/check-filesystem-governance.ts",
    "script:generate-filesystem-governance-report": "tsx scripts/generate-filesystem-governance-report.ts",
    "script:check-generated-artifact-governance": "tsx scripts/check-generated-artifact-governance.ts",
    "script:generate-generated-artifact-governance-report": "tsx scripts/generate-generated-artifact-governance-report.ts",
    "script:check-storage-governance": "tsx scripts/check-storage-governance.ts",
    "script:check-notebook-governance": "tsx scripts/check-notebook-governance.ts",
    "script:generate-storage-governance-report": "tsx scripts/generate-storage-governance-report.ts",
    "script:generate-file-survival-report": "tsx scripts/generate-file-survival-report.ts",
    "script:check-file-survival": "tsx scripts/check-file-survival.ts",
    "script:generate-governance-reports": "pnpm run script:generate-filesystem-governance-report && pnpm run script:generate-generated-artifact-governance-report && pnpm run script:generate-storage-governance-report && pnpm run script:generate-file-survival-report && pnpm run script:generate-governance-report && pnpm run script:generate-governance-register",
    "script:test-governance": "tsx --test scripts/lib/governance-spine.test.ts",
    "script:test-governance-honesty": "tsx --test scripts/lib/governance-honesty.test.ts",
    "script:test-naming-convention": "tsx --test scripts/lib/naming-convention.test.ts",
    "script:test-repo-guard": "tsx --test scripts/lib/repo-guard.test.ts",
    "script:validate-i18n-policy": "pnpm --filter @afenda/web run i18n:validate-policy",
    "script:i18n-check": "pnpm --filter @afenda/web i18n:check",
    "script:i18n-check:unused": "pnpm --filter @afenda/web i18n:check:unused",
    "script:generate-i18n-crossref-audit": "pnpm --filter @afenda/web run i18n:generate-crossref-audit",
    "script:generate-i18n-corpus": "pnpm --filter @afenda/web run i18n:generate-corpus",
    "script:sync-i18n-tolgee": "pnpm --filter @afenda/web run i18n:sync-tolgee",
    "script:check-color-consistency": "tsx scripts/check-color-consistency.ts",
    "script:ast-grep-scan": "ast-grep scan --config sgconfig.yml",
    "script:check-stem-sync": "tsx scripts/check-stem-sync.ts",
    "script:ui-color-governance": "pnpm run script:check-stem-sync && pnpm run script:check-color-consistency && node -e \"require('node:fs').mkdirSync('.artifacts/eslint',{recursive:true})\" && pnpm exec eslint packages/design-system apps/web/src --max-warnings 0 --cache --cache-location .artifacts/eslint --concurrency auto",
    "script:inspect-vitest-diagnostics": "tsx scripts/inspect-vitest-diagnostics.ts",
    "script:check-audit-writer-boundary": "pnpm --filter @afenda/database run audit:check-writer-boundary",
    "script:check-app-surface": "pnpm --filter @afenda/web run app-surface:check",
    "auth:migrate": "pnpm --filter @afenda/better-auth run auth:migrate",
    "auth:migrate:plugins": "pnpm --filter @afenda/better-auth run auth:migrate:plugins",
    "test:e2e:auth": "pnpm --filter @afenda/web run test:e2e",
    "db:generate": "pnpm -C packages/_database run db:generate",
    "db:migrate": "pnpm -C packages/_database run db:migrate",
    "db:push": "pnpm -C packages/_database run db:push",
    "db:push:force": "pnpm -C packages/_database run db:push:force",
    "db:pick-demo-tenant-id": "pnpm -C packages/_database run db:pick-demo-tenant-id",
    "resend": "dotenv -e .env -- resend",
    "resend:whoami": "dotenv -e .env -- resend whoami",
    "resend:doctor": "dotenv -e .env -- resend doctor",
    "resend:validate": "pnpm run resend:doctor"
  },
  "devDependencies": {
    "@afenda/env-loader": "workspace:*",
    "@afenda/eslint-config": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@ast-grep/cli": "^0.42.1",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "catalog:",
    "dotenv-cli": "^11.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "resend-cli": "^1.8.0",
    "shadcn": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run script:check-governance && pnpm exec lint-staged --concurrent false"
  }
}
