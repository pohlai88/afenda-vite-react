{
  "$schema": "./filesystem-governance.schema-note.json",
  "version": 1,
  "promotedSharedDirectories": ["share", "shared"],
  "ignoredDirectoryNames": ["__tests__", "coverage", "dist", "node_modules"],
  "deniedDirectoryNames": [
    "__test__",
    "content",
    "data",
    "helper",
    "helpers",
    "section",
    "sections",
    "util",
    "utils",
    "wrapper"
  ],
  "deniedFileStems": [
    "common",
    "content",
    "data",
    "helper",
    "helpers",
    "misc",
    "section",
    "sections",
    "util",
    "utils",
    "wrapper"
  ],
  "governedRoots": [
    {
      "root": "apps/web/src/marketing/pages",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/web/src/app/_features",
      "maxDirectoryDepth": 4,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/web/src/app/_platform",
      "maxDirectoryDepth": 4,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/web/src/share",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": ["share"]
    },
    {
      "root": "apps/web/src/routes",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/web/src/rpc",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/api/src/modules",
      "maxDirectoryDepth": 4,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/api/src/routes",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/api/src/middleware",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/api/src/contract",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "apps/api/src/lib",
      "maxDirectoryDepth": 3,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "packages/design-system/utils",
