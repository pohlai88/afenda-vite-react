    },
    {
      "root": "packages/design-system/hooks",
      "maxDirectoryDepth": 1,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "packages/design-system/icons",
      "maxDirectoryDepth": 1,
      "allowedPromotedSharedRoots": []
    },
    {
