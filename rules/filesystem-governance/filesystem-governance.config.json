      "maxDirectoryDepth": 1,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "packages/eslint-config/src",
      "maxDirectoryDepth": 2,
      "allowedPromotedSharedRoots": []
    },
    {
      "root": "packages/contracts/src",
      "maxDirectoryDepth": 2,
