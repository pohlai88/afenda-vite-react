# Environment Variables Example
# Copy this file to .env.local for local development
# See: https://vitejs.dev/guide/env-and-mode.html

# Application
VITE_APP_TITLE=My App
VITE_APP_VERSION=0.1.0

# API Configuration (browser fetch client — see `app/_platform/api-client`)
# Empty = same-origin paths (e.g. `/v1/...`); Vite `server.proxy` forwards `/api` → `apps/api`.
# VITE_API_BASE_URL=
# VITE_API_TIMEOUT=30000

# Workspace demo CRUD (`/app/workspace-demo`): tenant UUID that exists in `tenants` after migrations
# VITE_DEMO_TENANT_ID=

# Better Auth (full stack: `apps/api` + Postgres + this SPA)
# - Session cookies are sent on API requests via `credentials: "include"` on the api-client.
# - Server env: repo root `.env.database.example` → DATABASE_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL (e.g. http://localhost:5173), optional BETTER_AUTH_TRUSTED_ORIGINS.
# Optional: Neon Auth or any Better Auth–compatible HTTPS base (omit trailing slash).
# When unset, the SPA uses same-origin `/api` → self-hosted Better Auth in `apps/api`.
# VITE_BETTER_AUTH_BASE_URL=

# Afenda dev login: one-click block appears on /login when running `pnpm run dev` (no flag needed).
# Pair with API env AFENDA_DEV_LOGIN_* in repo-root .env — see docs/DEV_LOGIN.md
# Optional: prefill email on /login (same as seeded Better Auth user — not a secret)
# VITE_AFENDA_DEV_LOGIN_EMAIL=you@yourcompany.local
# VITE_AFENDA_DEV_LOGIN_LABEL=Core team dev

# Feature Flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_TOOLS=false

# External Services
# VITE_SENTRY_DSN=
# VITE_GOOGLE_ANALYTICS_ID=

# Note: Only variables prefixed with VITE_ are exposed to your app
# Never commit sensitive data to .env files - use .env.local (gitignored)
