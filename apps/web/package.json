{
  "name": "@afenda/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "lint:typeaware": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location .eslintcache --concurrency auto",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src\" \"public\" \"index.html\" \"*.config.*\"",
    "format:check": "prettier --check \"src\" \"public\" \"index.html\" \"*.config.*\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.96.2",
    "date-fns": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/tsconfig": "workspace:*",
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
