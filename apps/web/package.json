{
  "name": "@afenda/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node --disable-warning=ExperimentalWarning ./node_modules/vite/bin/vite.js --configLoader native",
    "build": "tsc -b && node --disable-warning=ExperimentalWarning ./node_modules/vite/bin/vite.js build --configLoader native",
    "preview": "node --disable-warning=ExperimentalWarning ./node_modules/vite/bin/vite.js preview --configLoader native",
    "typecheck": "tsc -b",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "lint:typeaware": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location .eslintcache --concurrency auto",
    "test": "node --disable-warning=ExperimentalWarning ./node_modules/vitest/vitest.mjs --configLoader native",
    "test:ui": "node --disable-warning=ExperimentalWarning ./node_modules/vitest/vitest.mjs --ui --configLoader native",
    "test:run": "node --disable-warning=ExperimentalWarning ./node_modules/vitest/vitest.mjs run --configLoader native",
    "test:coverage": "node --disable-warning=ExperimentalWarning ./node_modules/vitest/vitest.mjs run --coverage --configLoader native",
    "build:analyze": "tsc -b && node --disable-warning=ExperimentalWarning ./node_modules/vite/bin/vite.js build --mode analyze --configLoader native",
    "i18n:check": "i18n-check --locales src/app/_platform/i18n/locales --source en --format i18next --only missingKeys invalidKeys",
    "i18n:check:unused": "tsx src/app/_platform/i18n/scripts/check-i18n-policy.ts --unused",
    "i18n:policy": "tsx src/app/_platform/i18n/scripts/check-i18n-policy.ts",
    "format": "prettier --write \"src\" \"public\" \"index.html\" \"*.config.*\"",
    "format:check": "prettier --check \"src\" \"public\" \"index.html\" \"*.config.*\"",
    "shell:validation-report": "tsx --tsconfig tsconfig.app.json src/app/_platform/shell/scripts/write-shell-metadata-validation-report.ts",
    "shell:validation-report:compare": "tsx --tsconfig tsconfig.app.json src/app/_platform/shell/scripts/compare-shell-validation-reports.ts"
  },
  "dependencies": {
    "@afenda/database": "workspace:*",
    "@afenda/design-system": "workspace:*",
    "@better-auth/core": "1.6.3",
    "@better-auth/passkey": "1.6.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.3",
    "class-variance-authority": "catalog:",
    "date-fns": "catalog:",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "catalog:",
    "next-themes": "0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "recharts": "catalog:",
    "shadcn": "^4.1.2",
    "sonner": "catalog:",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "catalog:",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@babel/core": "^7.29.0",
    "@lingual/i18n-check": "^0.9.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "^0.183.1",
    "@vitejs/devtools": "0.1.13",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "catalog:",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "prettier": "catalog:",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
