{
  "name": "@afenda/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "lint:typeaware": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location .eslintcache --concurrency auto",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:analyze": "tsc -b && vite build --mode analyze",
    "i18n:check": "i18n-check --locales src/share/i18n/locales --source en --format i18next --only missingKeys invalidKeys",
    "i18n:check:unused": "i18n-check --locales src/share/i18n/locales --source en --format i18next --unused src --only unused",
    "format": "prettier --write \"src\" \"public\" \"index.html\" \"*.config.*\"",
    "format:check": "prettier --check \"src\" \"public\" \"index.html\" \"*.config.*\""
  },
  "dependencies": {
    "@afenda/core": "workspace:*",
    "@afenda/shadcn-ui": "workspace:*",
    "@afenda/ui": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "catalog:",
    "date-fns": "catalog:",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "recharts": "catalog:",
    "shadcn": "^4.1.2",
    "sonner": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vaul": "catalog:",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/tsconfig": "workspace:*",
    "@babel/core": "^7.29.0",
    "@lingual/i18n-check": "^0.9.3",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/devtools": "0.1.13",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "prettier": "catalog:",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "vite": "8.0.5",
    "vitest": "catalog:"
  }
}
