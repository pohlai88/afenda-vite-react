{
  "extends": "@afenda/tsconfig/react-app.json",
  "references": [{ "path": "../../../api" }],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": "../..",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "node"
    ]
  },
  "include": ["../../src/**/*.ts", "../../src/**/*.tsx"]
}
