{
  "name": "@afenda/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"require('node:fs').mkdirSync('.artifacts/eslint',{recursive:true})\" && eslint . --cache --cache-location .artifacts/eslint --concurrency auto",
    "test": "vitest --configLoader bundle",
    "test:run": "vitest run --configLoader bundle"
  },
  "dependencies": {
    "@afenda/billing": "workspace:*",
    "@afenda/better-auth": "workspace:*",
    "@afenda/database": "workspace:*",
    "@afenda/env-loader": "workspace:*",
    "@afenda/errors": "workspace:*",
    "@afenda/events": "workspace:*",
    "@afenda/knowledge-contracts": "workspace:*",
    "@afenda/knowledge-ai": "workspace:*",
    "@afenda/knowledge-domain": "workspace:*",
    "@afenda/knowledge-indexer": "workspace:*",
    "@afenda/knowledge-search": "workspace:*",
    "@afenda/metrics": "workspace:*",
    "@afenda/pino-logger": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "catalog:",
    "hono": "^4.12.15",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@hono/cli": "^0.1.10",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
