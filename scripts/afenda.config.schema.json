{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://afenda.local/schemas/afenda.config.json",
  "title": "Afenda monorepo configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "product",
    "workspace",
    "paths",
    "readmeTargets",
    "workspaceGovernance"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageManager", "rootPackageName", "defaultPackageScope"],
      "properties": {
        "packageManager": { "type": "string", "enum": ["pnpm"] },
        "rootPackageName": { "type": "string", "minLength": 1 },
        "defaultPackageScope": { "type": "string", "minLength": 1 }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["webApp", "typescriptSharedConfig"],
      "properties": {
        "webApp": { "type": "string", "minLength": 1 },
        "typescriptSharedConfig": { "type": "string", "minLength": 1 }
      }
    },
    "readmeTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "mode"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "mode": {
            "type": "string",
            "enum": [
              "docs-root",
              "docs-collections",
              "scripts",
              "generic-formal-directory"
            ]
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "includeChildDirectories": { "type": "boolean" }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "mode": { "const": "generic-formal-directory" }
              }
            },
            "then": {
              "required": ["title", "description"]
            }
          },
          {
            "if": {
              "properties": {
                "includeChildDirectories": { "const": true }
              },
              "required": ["includeChildDirectories"]
            },
            "then": {
              "properties": {
                "mode": { "const": "generic-formal-directory" }
              }
            }
          }
        ]
      }
    },
    "workspaceGovernance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootTopology",
        "packageTopology",
        "featureTemplate",
        "sharedPackageTemplate",
        "webClientSrc"
      ],
      "properties": {
        "rootTopology": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primaryProductDirectories",
            "allowedRootDirectories",
            "allowedHiddenRootDirectories",
            "storageDirectories",
            "requiredRootFiles"
          ],
          "properties": {
            "primaryProductDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "allowedRootDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "allowedHiddenRootDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "storageDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "requiredRootFiles": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "packageTopology": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "workspaceRootDirectories",
            "allowedManifestlessDirectories"
          ],
          "properties": {
            "workspaceRootDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "allowedManifestlessDirectories": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "featureTemplate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "featuresRoot",
            "requiredDirectories",
            "requiredFiles",
            "enforceWhenFeatureExists"
          ],
          "properties": {
            "featuresRoot": { "type": "string", "minLength": 1 },
            "requiredDirectories": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "requiredFiles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "enforceWhenFeatureExists": { "type": "boolean" }
          }
        },
        "sharedPackageTemplate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "packagePath",
            "requiredDirectories",
            "requireDirectoriesWhenPackageExists"
          ],
          "properties": {
            "packagePath": { "type": "string", "minLength": 1 },
            "requiredDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "requireDirectoriesWhenPackageExists": { "type": "boolean" }
          }
        },
        "webClientSrc": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "srcRoot",
            "allowedTopLevelDirectories",
            "requiredShareSubdirectories",
            "enforce"
          ],
          "properties": {
            "srcRoot": { "type": "string", "minLength": 1 },
            "allowedTopLevelDirectories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "requiredShareSubdirectories": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "enforce": { "type": "boolean" }
          }
        }
      }
    }
  }
}
