      "storageDirectories": [".legacy", "archives"],
      "requiredRootFiles": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        ".npmrc",
        "tsconfig.json",
        "eslint.config.js",
        "prettier.config.js",
