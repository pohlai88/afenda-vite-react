  "governance": {
    "version": 1,
    "idFamilies": [
      "GOV-FS",
      "GOV-ARCH",
      "GOV-DOC",
      "GOV-CI",
      "GOV-GEN",
      "GOV-STORAGE",
      "GOV-TEST",
      "GOV-UI",
      "GOV-TRUTH"
    ],
    "domains": [
      {
        "id": "GOV-FS-001",
        "title": "Filesystem governance",
        "owner": "governance-toolchain",
        "lifecycleStatus": "enforced",
        "enforcementMaturity": "blocking",
        "defaultSeverity": "error",
        "tier": "tier-3",
        "docs": {
          "primary": "rules/filesystem-governance/filesystem-governance.md",
          "references": [
            "docs/MONOREPO_BOUNDARIES.md",
            "docs/REPO_ARTIFACT_POLICY.md"
          ]
        },
        "localConfig": "rules/filesystem-governance/filesystem-governance.config.json",
        "checks": [
          {
            "id": "filesystem-check",
            "command": "pnpm run script:check-filesystem-governance",
            "scriptPath": "scripts/governance/check-filesystem-governance.ts"
          }
        ],
        "report": {
          "command": "pnpm run script:generate-filesystem-governance-report",
          "scriptPath": "scripts/governance/generate-filesystem-governance-report.ts"
        },
        "evidencePath": ".artifacts/reports/governance/filesystem.report.json",
        "ciBehavior": "block",
        "reviewCadence": "30d"
      },
      {
        "id": "GOV-GEN-001",
        "title": "Generated artifact governance",
        "owner": "governance-toolchain",
        "lifecycleStatus": "enforced",
        "enforcementMaturity": "blocking",
        "defaultSeverity": "error",
        "tier": "tier-3",
        "docs": {
          "primary": "rules/generated-artifact-governance/generated-artifact-governance.md",
          "references": ["docs/REPO_ARTIFACT_POLICY.md"]
