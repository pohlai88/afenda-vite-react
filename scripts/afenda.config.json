{
  "$schema": "./afenda.config.schema.json",
  "schemaVersion": 1,
  "product": {
    "name": "Afenda",
    "description": "Afenda ERP: Turborepo monorepo with React + Vite web client (apps/web)."
  },
  "workspace": {
    "packageManager": "pnpm",
    "rootPackageName": "afenda-monorepo",
    "defaultPackageScope": "@afenda/"
  },
  "paths": {
    "webApp": "apps/web",
    "typescriptSharedConfig": "packages/typescript-config"
  },
  "readmeTargets": [
    {
      "path": "docs",
      "mode": "docs-root",
      "description": "Generate the top-level documentation index for repo-wide guides."
    },
    {
      "path": "docs",
      "mode": "docs-collections",
      "description": "Generate README indexes for governed documentation subdirectories."
    },
    {
      "path": "scripts",
      "mode": "scripts",
      "description": "Generate the scripts directory index and support-file summary."
    },
    {
      "path": "rules",
      "mode": "generic-formal-directory",
      "title": "Repository rules",
      "description": "Generate an index for durable repository governance rules, machine-readable policy, and enforcement-tied governance records.",
      "includeChildDirectories": true
    },
    {
      "path": ".agents/skills/shadcn",
      "mode": "generic-formal-directory",
      "title": "Shadcn skill docs",
      "description": "Generate an index for the in-repo shadcn skill guidance and companion markdown references.",
      "includeChildDirectories": true
    }
  ],
  "fileSurvival": {
    "rollouts": [
      {
        "id": "marketing",
        "scopeRoot": "apps/web/src/marketing",
        "sharedRoots": ["apps/web/src/marketing/components"],
        "runtimeOwners": [
          "apps/web/src/marketing/marketing-layout.tsx",
          "apps/web/src/marketing/marketing-routes.tsx",
          "apps/web/src/marketing/marketing-page-registry.ts",
          "apps/web/src/marketing/marketing-theme-provider.tsx",
          "apps/web/src/marketing/marketing.config.ts",
          "apps/web/src/marketing/marketing-configured-home.tsx",
          "apps/web/src/marketing/marketing-random-home.tsx",
          "apps/web/src/marketing/marketing-loading-fallback.tsx"
        ],
        "rolePatterns": {
          "routeOwner": ["**/page.tsx", "**/*-page.tsx", "pages/landing/*.tsx"],
          "contentOwner": [
            "**/content.ts",
            "**/*-editorial.ts",
            "**/*.config.ts"
          ],
          "pageLocalComposition": [
            "pages/**/*.tsx",
            "pages/**/*-motion.ts",
            "pages/**/*-layers.tsx"
          ]
        },
        "ignore": [
          "**/__tests__/**",
          "**/*.css",
          "**/*.generated.*",
          "**/dist/**",
          "**/build/**"
        ],
        "reviewedExceptions": [],
        "protectedScopes": [
          {
            "id": "marketing-runtime",
            "roots": [
              "apps/web/src/marketing/marketing-layout.tsx",
              "apps/web/src/marketing/marketing-routes.tsx",
              "apps/web/src/marketing/marketing-page-registry.ts",
              "apps/web/src/marketing/marketing-theme-provider.tsx",
              "apps/web/src/marketing/marketing.config.ts",
              "apps/web/src/marketing/marketing-configured-home.tsx",
              "apps/web/src/marketing/marketing-random-home.tsx",
              "apps/web/src/marketing/marketing-loading-fallback.tsx"
            ]
          },
          {
            "id": "marketing-shared-surface",
            "roots": ["apps/web/src/marketing/components"]
          }
        ],
        "ownerTruth": [
          {
            "root": "apps/web/src/marketing/components",
            "owner": "marketing-shared-surface"
          },
          {
            "root": "apps/web/src/marketing/pages/company",
            "owner": "marketing-route:company"
          },
          {
            "root": "apps/web/src/marketing/pages/campaigns",
            "owner": "marketing-route:campaigns"
          },
          {
            "root": "apps/web/src/marketing/pages/legal",
            "owner": "marketing-route:legal"
          },
          {
            "root": "apps/web/src/marketing/pages/landing",
            "owner": "marketing-route:landing"
          },
          {
            "root": "apps/web/src/marketing/pages/product",
            "owner": "marketing-route:product"
          },
          {
            "root": "apps/web/src/marketing/pages/regional",
            "owner": "marketing-route:regional"
          },
          {
            "root": "apps/web/src/marketing/marketing-layout.tsx",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing-routes.tsx",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing-page-registry.ts",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing-theme-provider.tsx",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing.config.ts",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing-configured-home.tsx",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing-random-home.tsx",
            "owner": "marketing-runtime"
          },
          {
            "root": "apps/web/src/marketing/marketing-loading-fallback.tsx",
            "owner": "marketing-runtime"
          }
        ],
        "blockingPolicy": {
          "rolloutMode": "block",
          "blockingCategories": ["wrapper", "dead"],
          "blockingConfidence": ["high"],
          "protectedScopeBlockingCategories": [
            "unknown-role-protected-scope",
            "shared-single-use"
          ],
          "protectedScopeBlockingConfidence": ["high", "medium"]
        },
        "rolePrecedence": [
          "runtime-orchestrator",
          "registry",
          "route-owner",
          "editorial-content",
          "config",
          "shared-component",
          "page-local-composition",
          "unknown"
        ],
        "resolverUnresolvedWarningThreshold": 3
      }
    ]
  },
  "workspaceGovernance": {
    "rootTopology": {
      "primaryProductDirectories": ["apps", "packages"],
      "allowedRootDirectories": [
        "apps",
        "dist",
        "docs",
        "node_modules",
        "packages",
        "rules",
        "scripts"
      ],
      "allowedHiddenRootDirectories": [
        ".agents",
        ".artifacts",
        ".cursor",
        ".git",
        ".github",
        ".turbo",
        ".vscode"
