# Tolgee self-hosted instance configuration
# Copy to .env.tolgee and fill in values after running:
#   docker compose -f docker-compose.tolgee.yml up -d
#
# Then log in at http://localhost:8085, create a project, and generate a PAT.

# API base URL (no trailing slash)
TOLGEE_API_URL=http://localhost:8085

# Project ID (visible in the Tolgee UI project URL: /projects/{id})
TOLGEE_PROJECT_ID=

# API key (Personal Access Token or Project API Key)
TOLGEE_API_KEY=

# Port for docker-compose (optional, default 8085)
TOLGEE_PORT=8085

# JWT secret for local instance (change for any non-local deployment)
TOLGEE_JWT_SECRET=afenda-local-dev-secret-change-me
