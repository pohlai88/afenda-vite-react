# Prefer the consolidated Neon template at repo root:
#   `.env.neon.example`  → copy to `.env.neon` (gitignored) and fill from Neon MCP / Console.
#
# Copy to `.env.neon` and/or `.env` at repo root (or export in your shell) for local API + Drizzle.
# `apps/api`, Drizzle, and Better Auth CLI load **`.env.neon` first**, then **`.env`** (missing keys only).
# Never commit real URLs or passwords.

# --- Neon Postgres (Console → Connection string, or Neon MCP `get_connection_string`) ---
# Use the *pooler* URI for serverless / many short-lived connections.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Afenda `@afenda/database` + Drizzle ---
# After DATABASE_URL is set:
#   pnpm --filter @afenda/database db:migrate

# --- Better Auth (when self-hosting in `apps/api` with `createAfendaAuth`) ---
# BETTER_AUTH_SECRET=   # min 32 chars; openssl rand -base64 32
# Public URL the SPA uses for auth (Vite dev: same origin as the client, usually port 5173).
# BETTER_AUTH_URL=http://localhost:5173
# Optional: comma-separated extra trusted browser origins (CSRF). Defaults include localhost:5173 and :3001.
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# After DATABASE_URL + BETTER_AUTH_SECRET are set, apply Better Auth tables (Kysely migrate):
#   pnpm --filter @afenda/better-auth auth:migrate
# DEMO_TENANT_ID=      # optional dev fallback UUID for X-Tenant-Id (same as VITE_DEMO_TENANT_ID)
# Optional UUID: when Better Auth `databaseHooks` emit security audit rows and the user has no active Afenda tenant membership yet, use this tenant_id (create a dedicated "platform" tenant in dev).
# AFENDA_AUTH_AUDIT_FALLBACK_TENANT_ID=

# --- Better Auth plugins (optional; run `pnpm --filter @afenda/better-auth auth:migrate` after enabling) ---
# AFENDA_AUTH_PASSKEY_ENABLED=true
# AFENDA_AUTH_PASSKEY_RP_ID=localhost
# AFENDA_AUTH_PASSKEY_RP_NAME=Afenda
# AFENDA_AUTH_MFA_ENABLED=true
# AFENDA_AUTH_MFA_ISSUER=Afenda

# --- Neon Auth (managed Better Auth–compatible service; optional alternative to self-hosted) ---
# If you use Neon Auth for the browser, set the SPA URL in apps/web (see apps/web/.env.example).
# Do not point both Neon Auth and the local `/api/auth/*` handler at the same client without a clear split.
