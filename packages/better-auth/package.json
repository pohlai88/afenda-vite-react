{
  "name": "@afenda/better-auth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@afenda/database": "workspace:*",
    "@afenda/env-loader": "workspace:*",
    "better-auth": "^1.6.3",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "auth:migrate": "pnpm dlx auth@latest migrate --config ./src/better-auth-cli-config.ts --yes",
    "auth:generate": "pnpm dlx auth@latest generate --config ./src/better-auth-cli-config.ts --yes",
    "auth:info": "pnpm dlx auth@latest info --config ./src/better-auth-cli-config.ts"
  }
}
