{
  "extends": "@afenda/tsconfig/base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "vitest/globals"]
  },
  "include": ["./src/vitest/**/*.ts"],
  "exclude": ["./src/**/*.test.ts", "./src/**/__tests__/**"]
}
