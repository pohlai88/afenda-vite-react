{
  "name": "@afenda/vitest-config",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Shared Vitest defaults, setup, and types for Afenda workspace packages and apps.",
  "sideEffects": [
    "./dist/vitest/setup.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest --configLoader bundle",
    "test:run": "vitest run --configLoader bundle",
    "test:coverage": "vitest run --coverage --configLoader bundle"
  },
  "exports": {
    "./vitest/defaults": {
      "types": "./dist/vitest/defaults.d.ts",
      "import": "./dist/vitest/defaults.js",
      "default": "./dist/vitest/defaults.js"
    },
    "./vitest/setup": {
      "types": "./dist/vitest/setup.d.ts",
      "import": "./dist/vitest/setup.js",
      "default": "./dist/vitest/setup.js"
    },
    "./vitest/vite-module-resolution-plugin": {
      "types": "./dist/vitest/vite-module-resolution-plugin.d.ts",
      "import": "./dist/vitest/vite-module-resolution-plugin.js",
      "default": "./dist/vitest/vite-module-resolution-plugin.js"
    }
  },
  "peerDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.0"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "^29.0.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
