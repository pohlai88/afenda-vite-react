{
  "name": "@afenda/vitest-config",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Shared Vitest defaults, setup, and types for Afenda workspace packages and apps.",
  "sideEffects": [
    "./src/vitest/setup.ts"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "exports": {
    "./vitest/defaults": {
      "types": "./src/vitest/defaults.ts",
      "import": "./src/vitest/defaults.ts",
      "default": "./src/vitest/defaults.ts"
    },
    "./vitest/setup": {
      "types": "./src/vitest/setup.ts",
      "import": "./src/vitest/setup.ts",
      "default": "./src/vitest/setup.ts"
    }
  },
  "peerDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "^29.0.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
