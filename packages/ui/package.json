{
  "name": "@afenda/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\""
  },
  "exports": {
    "./components/*": "./src/components/ui/*.tsx",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./lib": "./src/lib/index.ts",
    "./lib/*": "./src/lib/*.ts",
    "./hooks": "./src/hooks/index.ts",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.50.0",
    "zod": "^3.22.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@hookform/resolvers": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "catalog:"
  }
}
