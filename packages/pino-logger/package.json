{
  "name": "@afenda/pino-logger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Structured Pino logging primitives and Hono request logging for Afenda services.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "hono": "^4.7.4",
    "pino": "^9.13.1"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint src --cache --cache-location .eslintcache --concurrency auto",
    "test": "vitest --configLoader bundle",
    "test:run": "vitest run --configLoader bundle"
  }
}
