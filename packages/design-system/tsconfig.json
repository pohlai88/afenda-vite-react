{
  "extends": "../typescript-config/react-library.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "paths": {
      "@afenda/design-system": ["./index.ts"],
      "@afenda/design-system/utils": ["./utils/index.ts"],
      "@afenda/design-system/utils/*": ["./utils/*"],
      "@afenda/design-system/ui-primitives": ["./ui-primitives/index.ts"],
      "@afenda/design-system/ui-primitives/*": ["./ui-primitives/*"],
      "@afenda/design-system/hooks": ["./hooks/index.ts"],
      "@afenda/design-system/hooks/*": ["./hooks/*"],
      "@afenda/design-system/icons": ["./icons/index.ts"],
      "@afenda/design-system/icons/*": ["./icons/*"],
      "@afenda/design-system/scripts": [
        "./design-architecture/scripts/index.ts"
      ]
    }
  },
  "include": [
    "vite-env.d.ts",
    "index.ts",
    "vitest.config.ts",
    "scripts/**/*.ts",
    "utils/**/*.ts",
    "hooks/*.ts",
    "hooks/**/*.ts",
    "ui-primitives/**/*.ts",
    "ui-primitives/**/*.tsx",
    "design-architecture/**/*.ts",
    "design-architecture/**/*.tsx",
    "icons/**/*.ts",
    "icons/**/*.tsx"
  ],
  "exclude": ["**/z_archive/**"]
}
