{
  "name": "@afenda/design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Canonical design system: tokens, UI primitives, icon infrastructure, and shadcn-compatible runtime artifacts.",
  "types": "./index.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "validate-tokens": "pnpm exec vitest run design-architecture/__tests__ --configLoader native",
    "tokens:check": "pnpm run validate-tokens",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "format": "prettier --write \"utils/**/*.ts\" \"scripts/**/*.ts\" \"ui-primitives/**/*.{ts,tsx}\" \"design-architecture/scripts/**/*.ts\" \"icons/**/*.{ts,tsx}\" \"components.json\" \"hooks/**/*.{ts,tsx}\" \"prettier.config.js\"",
    "format:check": "prettier --check \"utils/**/*.ts\" \"scripts/**/*.ts\" \"ui-primitives/**/*.{ts,tsx}\" \"design-architecture/scripts/**/*.ts\" \"icons/**/*.{ts,tsx}\" \"components.json\" \"hooks/**/*.{ts,tsx}\" \"prettier.config.js\"",
    "icons:generate": "tsx icons/script/build-icons.ts",
    "icons:check": "tsx icons/script/build-icons.ts && git diff --exit-code -- icons",
    "check:imports": "tsx design-architecture/scripts/check-design-system-imports.ts",
    "check:tw": "tsx scripts/check-tailwind-tokens.ts",
    "component-governance:generate": "tsx scripts/component-governance/generate.ts",
    "component-governance:check": "tsx scripts/component-governance/check.ts",
    "test:run": "vitest run --configLoader native",
    "test:coverage": "vitest run --coverage --configLoader native",
    "test": "vitest --configLoader native"
  },
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts",
      "default": "./index.ts"
    },
    "./utils": {
      "types": "./utils/index.ts",
      "import": "./utils/index.ts",
      "default": "./utils/index.ts"
    },
    "./utils/*": "./utils/*",
    "./ui-primitives": {
      "types": "./ui-primitives/index.ts",
      "import": "./ui-primitives/index.ts",
      "default": "./ui-primitives/index.ts"
    },
    "./ui-primitives/_registry": {
      "types": "./ui-primitives/_registry.ts",
      "import": "./ui-primitives/_registry.ts",
      "default": "./ui-primitives/_registry.ts"
    },
    "./ui-primitives/*": "./ui-primitives/*",
    "./scripts": {
      "types": "./design-architecture/scripts/index.ts",
      "import": "./design-architecture/scripts/index.ts",
      "default": "./design-architecture/scripts/index.ts"
    },
    "./icons": {
      "types": "./icons/index.ts",
      "import": "./icons/index.ts",
      "default": "./icons/index.ts"
    },
    "./hooks": {
      "types": "./hooks/index.ts",
      "import": "./hooks/index.ts",
      "default": "./hooks/index.ts"
    },
    "./hooks/*": "./hooks/*",
    "./design-architecture/local.css": "./design-architecture/src/local.css"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-table": "^8.21.3",
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "catalog:",
    "@hugeicons/react": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "@remixicon/react": "catalog:",
    "@tabler/icons-react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "catalog:",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.66.0",
    "react-textarea-autosize": "^8.5.9",
    "react-resizable-panels": "^4.9.0",
    "recharts": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "^3.3.1",
    "vaul": "catalog:",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "fast-glob": "^3.3.3",
    "tsx": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
