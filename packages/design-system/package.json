{
  "name": "@afenda/design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Design tokens (Style Dictionary), generated CSS themes, and canonical shadcn reference UI under src/components/shadcn only. Legacy components outside that tree are deprecated; app runtime uses @afenda/shadcn-ui.",
  "preinstall": "npx only-allow pnpm",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"internals/**/*.js\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"internals/**/*.js\" \"*.js\"",
    "generate-demo-tailwind-classes": "node internals/tokens/generate-demo-tailwind-classes.js",
    "cleanse-css-for-tailwind": "node internals/tokens/cleanse-css-for-tailwind.js",
    "transform-tokens": "node ./transformTokens.js",
    "extract-design-tokens": "node internals/tokens/extract-design-tokens.js",
    "generate-styles": "pnpm run extract-design-tokens && pnpm run transform-tokens && pnpm run cleanse-css-for-tailwind && pnpm run generate-demo-tailwind-classes",
    "clean": "rimraf node_modules .turbo tsconfig.tsbuildinfo coverage"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "catalog:",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "catalog:",
    "embla-carousel-react": "^8.6.0",
    "formik": "^2.4.6",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lodash": "^4.17.21",
    "lucide-react": "catalog:",
    "prop-types": "^15.8.1",
    "radix-ui": "^1.4.3",
    "react-accessible-treeview": "^2.11.2",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.62.0",
    "react-intersection-observer": "^9.16.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.11",
    "vaul": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@types/lodash": "^4.17.20",
    "@types/node": "catalog:",
    "@types/prop-types": "^15.7.15",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "color": "^4.2.3",
    "deepmerge": "^4.3.1",
    "glob": "^8.1.0",
    "rimraf": "^6.0.1",
    "style-dictionary": "^3.9.2",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
