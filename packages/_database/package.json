{
  "name": "@afenda/database",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Canonical server-only PostgreSQL and Drizzle persistence boundary for Afenda.",
  "types": "./src/index.ts",
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "test": "vitest --configLoader native",
    "test:run": "vitest run --configLoader native",
    "test:coverage": "vitest run --coverage --configLoader native",
    "db:guard": "pnpm run typecheck && tsx scripts/guard-schema-modules.ts && vitest run src/governance/__tests__ src/schema/__tests__/schema-contract.test.ts",
    "db:guard:ci": "tsx scripts/guard-schema-modules.ts && vitest run src/governance/__tests__ src/schema/__tests__/schema-contract.test.ts",
    "db:generate": "pnpm run db:guard && drizzle-kit generate",
    "db:check-migrations": "tsx scripts/check-migrations.ts",
    "db:verify-migrations-sync": "tsx scripts/verify-migrations-sync.ts",
    "db:ci": "pnpm run studio:check && pnpm run db:guard:ci && pnpm run db:check-migrations && pnpm run db:verify-migrations-sync",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "studio:sync": "tsx scripts/sync-studio-snapshots.ts",
    "studio:check": "tsx scripts/assert-studio-snapshots-synced.ts",
    "glossary:sync": "pnpm run studio:sync"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./authorization": {
      "types": "./src/authorization/index.ts",
      "import": "./src/authorization/index.ts",
      "default": "./src/authorization/index.ts"
    },
    "./tenancy": {
      "types": "./src/tenancy/index.ts",
      "import": "./src/tenancy/index.ts",
      "default": "./src/tenancy/index.ts"
    },
    "./audit": {
      "types": "./src/audit/index.ts",
      "import": "./src/audit/index.ts",
      "default": "./src/audit/index.ts"
    },
    "./governance": {
      "types": "./src/governance/index.ts",
      "import": "./src/governance/index.ts",
      "default": "./src/governance/index.ts"
    },
    "./studio": {
      "types": "./src/studio/index.ts",
      "import": "./src/studio/index.ts",
      "default": "./src/studio/index.ts"
    },
    "./studio/snapshots": {
      "types": "./src/studio/studio-snapshots-public.ts",
      "import": "./src/studio/studio-snapshots-public.ts",
      "default": "./src/studio/studio-snapshots-public.ts"
    }
  },
  "dependencies": {
    "@afenda/env-loader": "workspace:*",
    "@faker-js/faker": "^10.4.0",
    "drizzle-orm": "catalog:",
    "drizzle-seed": "^0.3.1",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "^2.8.3"
  }
}
