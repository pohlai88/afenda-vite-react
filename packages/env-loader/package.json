{
  "name": "@afenda/env-loader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Loads monorepo-root `.env.neon` into process.env for API, Drizzle, and Vite.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto"
  }
}
