{
  "name": "@afenda/env-loader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Loads monorepo-root `.env` then `.env.local` into process.env for API, Drizzle, and CLI (see repo-root `.env.example`).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "node -e \"require('node:fs').mkdirSync('.artifacts/eslint',{recursive:true})\" && eslint . --cache --cache-location .artifacts/eslint --concurrency auto"
  }
}
