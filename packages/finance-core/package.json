{
  "name": "@afenda/finance-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Database-agnostic accounting and Vietnam tax primitives for Afenda finance workloads.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "node -e \"require('node:fs').mkdirSync('.artifacts/eslint',{recursive:true})\" && eslint src tests --cache --cache-location .artifacts/eslint --concurrency auto",
    "test": "vitest --configLoader bundle",
    "test:run": "vitest run --configLoader bundle"
  }
}
