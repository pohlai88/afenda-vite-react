{
  "name": "@afenda/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --cache --cache-location .eslintcache --concurrency auto",
    "test": "vitest --configLoader bundle",
    "test:run": "vitest run --configLoader bundle",
    "smoke:auth": "tsx scripts/smoke-auth-e2e.ts"
  },
  "dependencies": {
    "@afenda/better-auth": "workspace:*",
    "@afenda/database": "workspace:*",
    "@afenda/env-loader": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "drizzle-orm": "catalog:",
    "hono": "^4.7.4",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@afenda/vitest-config": "workspace:*",
    "@hono/cli": "^0.1.10",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
