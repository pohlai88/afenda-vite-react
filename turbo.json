{
  "$schema": "https://turbo.build/schema.json",
  "cacheDir": ".artifacts/cache/turbo",
  "ui": "tui",
  "globalDependencies": [
    "pnpm-workspace.yaml",
    "turbo.json",
    "eslint.config.js"
  ],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build:analyze": {
      "dependsOn": ["^build", "^transit"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "MODE", "VITE_*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.env",
        "$TURBO_ROOT$/.env.*",
        "$TURBO_ROOT$/packages/typescript-config/**/*.json"
      ]
    },
    "build": {
      "dependsOn": ["^build", "^transit"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "MODE", "VITE_*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.env",
        "$TURBO_ROOT$/.env.*",
        "$TURBO_ROOT$/packages/typescript-config/**/*.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build", "^transit"],
      "outputs": ["node_modules/.tmp/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/packages/typescript-config/**/*.json"
      ]
    },
    "lint": {
      "dependsOn": ["^transit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.js",
        "$TURBO_ROOT$/packages/eslint-config/src/**"
      ]
    },
    "test": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "VITE_*"],
      "passThroughEnv": ["VITEST_*"]
    },
    "test:ui": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "VITE_*"],
      "passThroughEnv": ["VITEST_*"]
    },
    "test:run": {
      "dependsOn": ["^transit"],
      "env": ["NODE_ENV", "VITE_*"],
      "passThroughEnv": ["VITEST_*"]
    },
    "test:coverage": {
      "dependsOn": ["^transit"],
      "outputs": [".artifacts/vitest/coverage/**"],
      "env": ["NODE_ENV", "VITE_*"],
      "passThroughEnv": ["VITEST_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "VITE_*"],
      "passThroughEnv": [
        "VITE_*",
        "DATABASE_URL",
        "PORT",
        "DB_POOL_MAX",
        "DB_IDLE_TIMEOUT_MS",
        "DB_CONNECTION_TIMEOUT_MS",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRETS",
        "DEMO_TENANT_ID",
        "NEON_PROJECT_ID",
        "NEON_BRANCH_ID",
        "NEON_DATABASE",
        "NEON_AUTH_BASE_URL",
        "NEON_AUTH_JWKS_URL"
      ]
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["NODE_ENV", "PORT", "VITE_*"]
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "tokens:check": {
      "dependsOn": ["^transit"],
      "cache": false
    }
  }
}
