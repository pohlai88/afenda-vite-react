# =============================================================================
# Afenda monorepo — environment template (committed). Copy to `.env` at repo root.
# =============================================================================
#
# Usage
#   cp .env.example .env
#   Fill secrets locally. `.env` is gitignored.
#
# Vite (`apps/web`) uses `envDir` = repo root — see https://vitejs.dev/guide/env-and-mode.html
# Only `VITE_*` keys are exposed to the browser bundle; keep secrets unprefixed.
#
# Server tooling (`apps/api`, Drizzle, Better Auth CLI) loads via `@afenda/env-loader`:
#   repo root `.env` then `.env.local` (override: false).
#
# Vite also reads `.env.development` / `.env.production` and matching `*.local` in this directory.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Vite — client (public; shipped in JS — never put secrets here)
# -----------------------------------------------------------------------------
VITE_APP_TITLE=My App
VITE_APP_VERSION=0.1.0

# Base path for deployed assets/router (default "/")
# VITE_BASE_URL=/

# API — browser client (`app/_platform/api-client`). Empty = same-origin; dev proxy uses VITE_API_URL below.
# VITE_API_BASE_URL=
# VITE_API_TIMEOUT=30000

# Better Auth SPA → API base (omit trailing slash). Unset = same-origin `/api` → `apps/api`.
# VITE_BETTER_AUTH_BASE_URL=

# Full Better Auth client plugin stack (default on). Set to `false` to use legacy per-feature flags only.
# VITE_AFENDA_AUTH_ALL_PLUGINS=true
#
# Optional: restrict which sign-in methods the login UI shows for a tenant (JSON array). Server plugins stay enabled.
# VITE_AFENDA_TENANT_AUTH_METHODS=["password","social","passkey"]
#
# Passkey / MFA: set `AFENDA_AUTH_*` once in server section; `vite.config` injects matching
# `import.meta.env.VITE_AFENDA_AUTH_*` (override with explicit `VITE_*` if needed).
# VITE_AFENDA_AUTH_PASSKEY_ENABLED=true   # optional override — else mirrors AFENDA_AUTH_PASSKEY_ENABLED
# VITE_AFENDA_AUTH_MFA_ENABLED=true
# VITE_AFENDA_AUTH_MAGIC_LINK_ENABLED=true  # optional; mirrors AFENDA_AUTH_MAGIC_LINK_ENABLED (Better Auth magic link plugin)
# VITE_AFENDA_AUTH_REQUIRE_EMAIL_VERIFICATION=true  # optional; vite.config also reads unprefixed AFENDA_*

# Better Auth Infrastructure — optional; Vite enables `dashClient` when `BETTER_AUTH_API_KEY` is set.
# Set only to opt out: VITE_BETTER_AUTH_INFRA=false

# Workspace demo / governed API — UUID in `mdm.tenants` (must match user memberships).
# Set once: `pnpm run db:pick-demo-tenant-id` → copy into DEMO_TENANT_ID (client gets VITE_ via vite define).
# DEMO_TENANT_ID=

# Shell / docs
# VITE_DOCS_BASE_URL=

# Feature flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_TOOLS=false

# External client-side services
# VITE_SENTRY_DSN=
# VITE_GOOGLE_ANALYTICS_ID=

# Legacy / alternate IdP examples (if used)
# VITE_AUTH0_DOMAIN=
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=

# -----------------------------------------------------------------------------
# Vite — dev server & preview (config-time; still use VITE_ prefix here)
# -----------------------------------------------------------------------------
VITE_PORT=5173
VITE_HOST=localhost
# VITE_OPEN_BROWSER=true

# Proxy target for `/api` and `/api/v1` during `vite dev`
VITE_API_URL=http://localhost:8787

# VITE_HMR_PORT=24678
# VITE_PREVIEW_PORT=4173
# VITE_PREVIEW_HOST=localhost

# -----------------------------------------------------------------------------
# API (`apps/api`)
# -----------------------------------------------------------------------------
PORT=8787

# Legacy TPM intake connector (server only; used by `/api/v1/legacy-erp/pull/counterparties`)
# LEGACY_TPM_API_URL=http://localhost:3001/api
# LEGACY_TPM_API_TOKEN=
# LEGACY_TPM_TENANT_ID=

# Legacy MRP intake connector (server only; used by `/api/v1/legacy-erp/pull/items`)
# LEGACY_MRP_API_URL=http://localhost:3002/api
# LEGACY_MRP_API_TOKEN=
# LEGACY_MRP_TENANT_ID=

# -----------------------------------------------------------------------------
# PostgreSQL / Neon
# -----------------------------------------------------------------------------
# Pooler URI from Neon Console or MCP (`get_connection_string`)
# DATABASE_URL=postgresql://USER:PASSWORD@HOSTPOOLER/neondb?sslmode=require
#
# Better Auth + Drizzle share this URL via `createPgPool()` (`@afenda/database`). Default schema is
# `public` unless you set search_path on the connection, e.g. non-public Better Auth tables:
#   ?options=-c%20search_path%3Dauth
# (Create the schema and grants first; see https://better-auth.com/docs/adapters/postgresql )
#
# Optional pool tuning (read by `createPgPool` — server only):
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=10000
# DB_CONNECTION_TIMEOUT_MS=5000
# DB_STATEMENT_TIMEOUT_MS=30000

# NEON_PROJECT_ID=
# NEON_BRANCH_ID=
# NEON_DATABASE=neondb

# -----------------------------------------------------------------------------
# Better Auth (server — `apps/api` + `@afenda/better-auth`)
# -----------------------------------------------------------------------------
# Production (NODE_ENV=production): BETTER_AUTH_SECRET (≥32 chars), BETTER_AUTH_URL (https or localhost),
# and preferably explicit BETTER_AUTH_TRUSTED_ORIGINS — validated at `createAfendaAuth` startup.
# Never commit real secrets; never use VITE_* for server-only values.
#
# BETTER_AUTH_SECRET=
# openssl rand -base64 32
# Public URL the browser uses for auth (Vite dev is usually http://localhost:5173)
# BETTER_AUTH_URL=http://localhost:5173
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# BETTER_AUTH_SECRETS=

# Optional tenant fallbacks (dev) — prefer `DEMO_TENANT_ID` in Vite section above for workspace demo
# AFENDA_AUTH_AUDIT_FALLBACK_TENANT_ID=

# Resend — transactional email from `@afenda/better-auth` (verify, reset, change-email, delete-account, …)
# https://resend.com/docs — verify a sending domain; `onboarding@resend.dev` is OK for quick tests
#
# Re-verify after rotating keys:
#   pnpm run resend:whoami
#   pnpm run resend:doctor    # connectivity + “full access” MCP/CLI vs sending-only app keys
#
# API keys:
# - App runtime only needs a key that can call `POST /emails` (sending).
# - “Full access” / domain management is for Resend CLI, MCP, and dashboard-style tools — not required for `createAfendaAuth`.
#   https://resend.com/api-keys
#
# Startup enforcement (packages/better-auth `createAfendaAuth`):
# - `NODE_ENV=production` → requires RESEND_API_KEY (must look like `re_…`) + RESEND_FROM_EMAIL unless you opt out with:
# AFENDA_AUTH_SKIP_RESEND_ENV_CHECK=true
# - or set AFENDA_AUTH_REQUIRE_EMAIL_DELIVERY=true in any environment for the same check.
#
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Afenda <onboarding@resend.dev>
# Optional display name in subjects / bodies (default "Afenda")
# AFENDA_AUTH_EMAIL_APP_NAME=Afenda
#
# Optional: same strict Resend check in non-production (e.g. staging).
# AFENDA_AUTH_REQUIRE_EMAIL_DELIVERY=false
#
# When `true`, users must verify email before password sign-in; register UX routes to login until verified.
# Pair with Vite: same value is injected as import.meta.env.VITE_AFENDA_AUTH_REQUIRE_EMAIL_VERIFICATION
# AFENDA_AUTH_REQUIRE_EMAIL_VERIFICATION=false

# -----------------------------------------------------------------------------
# Afenda Better Auth — full stack (see `packages/better-auth/src/build-afenda-auth-plugins.ts`)
# -----------------------------------------------------------------------------
# Default: all supported plugins are on. Set to `false` for legacy per-flag opt-in (passkey, MFA, magic link, agent, One Tap).
# AFENDA_AUTH_ALL_PLUGINS=true
#
# Kill-switches (set `true` to disable a plugin): AFENDA_AUTH_DISABLE_PASSKEY, _MFA, _MAGIC_LINK, _AGENT_AUTH,
# _GOOGLE_ONE_TAP, _USERNAME, _EMAIL_OTP, _ADMIN, _API_KEY, _DEVICE_AUTHORIZATION, _JWT, _BEARER,
# _LAST_LOGIN_METHOD, _MULTI_SESSION, _ONE_TIME_TOKEN, _OAUTH_PROXY, _GENERIC_OAUTH, _CAPTCHA, _MCP_PLUGIN
#
# OAuth 2.0 device grant (`deviceAuthorization`) vs Agent Auth: Better Auth registers both on `POST /device/code`.
# With the default full stack, only Agent Auth is registered; OAuth device grant is omitted unless Agent Auth is off
# (`AFENDA_AUTH_DISABLE_AGENT_AUTH=true` for RFC 8628 device flow; mirror `VITE_AFENDA_AUTH_DISABLE_AGENT_AUTH=true` for the web client).
#
# Legacy per-feature flags (used only when AFENDA_AUTH_ALL_PLUGINS=false):
# AFENDA_AUTH_PASSKEY_ENABLED=true
# AFENDA_AUTH_PASSKEY_RP_ID=localhost
# AFENDA_AUTH_PASSKEY_RP_NAME=Afenda
# AFENDA_AUTH_MFA_ENABLED=true
# AFENDA_AUTH_MFA_ISSUER=Afenda
# AFENDA_AUTH_MAGIC_LINK_ENABLED=true
#
# Email OTP — https://better-auth.com/docs/plugins/email-otp — Resend (`sendVerificationOtpEmail` in `@afenda/better-auth`).
#
# Generic OAuth — JSON array of provider configs (https://better-auth.com/docs/plugins/generic-oauth):
# AFENDA_AUTH_GENERIC_OAUTH_JSON=[{"providerId":"custom","clientId":"…","clientSecret":"…","discoveryUrl":"https://…/.well-known/openid-configuration"}]
#
# Captcha — https://better-auth.com/docs/plugins/captcha (optional; plugin registers when secret is set)
# AFENDA_AUTH_CAPTCHA_PROVIDER=cloudflare-turnstile
# AFENDA_AUTH_CAPTCHA_SECRET_KEY=
# AFENDA_AUTH_CAPTCHA_SITE_KEY=   # hcaptcha / captchafox
#
# OAuth proxy — https://better-auth.com/docs/plugins/oauth-proxy
# AFENDA_AUTH_OAUTH_PROXY_PRODUCTION_URL=
# AFENDA_AUTH_OAUTH_PROXY_CURRENT_URL=
#
# JWT plugin — https://better-auth.com/docs/plugins/jwt
# AFENDA_AUTH_JWT_ISSUER=
# AFENDA_AUTH_JWT_AUDIENCE=   # comma-separated if multiple
#
# MCP *provider* plugin (app OAuth for MCP) — https://better-auth.com/docs/plugins/mcp
# AFENDA_AUTH_MCP_LOGIN_PAGE=/auth/login
# AFENDA_AUTH_MCP_RESOURCE=
#
# Agent Auth — https://better-auth.com/docs/plugins/agent-auth — discovery `/.well-known/agent-configuration`
# AFENDA_AUTH_AGENT_PROVIDER_NAME=Afenda
# AFENDA_AUTH_AGENT_PROVIDER_DESCRIPTION=
# AFENDA_AUTH_AGENT_DEVICE_AUTHORIZATION_PAGE=/device/capabilities
# AFENDA_AUTH_AGENT_TRUST_PROXY=false
#
# Google One Tap — requires `GOOGLE_CLIENT_ID` + `GOOGLE_CLIENT_SECRET`; Vite uses `VITE_GOOGLE_CLIENT_ID`.
# AFENDA_AUTH_GOOGLE_ONE_TAP_ENABLED=true
# AFENDA_AUTH_STEP_UP_POLICY=risk_based   # or omit / off — logged in dev by createAfendaAuth
#
# Optional second OAuth in Better Auth UI — set when server registers GitHub (`GITHUB_CLIENT_ID` / secret).
# VITE_GITHUB_CLIENT_ID=
#
# Vitest / integration tests only — adds Better Auth `testUtils` (https://www.better-auth.com/docs/plugins/test-utils)
# NODE_ENV=test also enables it. Privileged helpers on `ctx.test` — keep out of production.
# AFENDA_AUTH_TEST_UTILS=true
# OTP capture for `emailOTP` tests (`ctx.test.getOTP`) — default on; set `false` to disable in-memory capture
# AFENDA_AUTH_TEST_UTILS_CAPTURE_OTP=true

# Better Auth Infrastructure (https://better-auth.com/docs/infrastructure/getting-started)
# BETTER_AUTH_API_KEY=   # server + Vite client plugin (no separate VITE_* key required)

# -----------------------------------------------------------------------------
# Neon Auth (optional — public HTTPS endpoints if browser uses Neon Auth)
# -----------------------------------------------------------------------------
# NEON_AUTH_BASE_URL=https://<endpoint>.neonauth.<region>.aws.neon.tech/<database>/auth
# NEON_AUTH_JWKS_URL=https://<endpoint>.neonauth.<region>.aws.neon.tech/<database>/auth/.well-known/jwks.json

# -----------------------------------------------------------------------------
# Tolgee (i18n scripts: `pnpm run script:generate-i18n-corpus`, `script:sync-i18n-tolgee`)
# Self-host: docker compose -f docker-compose.tolgee.yml up -d
# -----------------------------------------------------------------------------
# TOLGEE_API_URL=http://localhost:8085
# TOLGEE_PROJECT_ID=
# TOLGEE_API_KEY=
# TOLGEE_PORT=8085
# TOLGEE_JWT_SECRET=change-me-in-non-local

# -----------------------------------------------------------------------------
# OAuth — Better Auth social providers (optional; `packages/better-auth`)
# -----------------------------------------------------------------------------
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Local dev — login prefill (password stays here only; never VITE_*)
# -----------------------------------------------------------------------------
# AFENDA_DEV_LOGIN_ENABLED=true
# AFENDA_DEV_LOGIN_EMAIL=you@example.com
# AFENDA_DEV_LOGIN_PASSWORD=
# Vite injects email + flags into the SPA for prefill + hint — no password in the bundle.

# -----------------------------------------------------------------------------
# Turborepo — optional remote cache (CI + local)
# https://turborepo.com/docs/core-concepts/remote-caching
#
# GitHub Actions (this repo’s `.github/workflows/ci.yml`):
#   - Repository secret:  TURBO_TOKEN   (from Vercel → Account → Tokens, or turbo login)
#   - Repository variable: TURBO_TEAM  (Vercel team slug / scope shown in turbo link)
#   If either is unset, CI still runs; tasks use the local cache only.
#
# Local machine: `pnpm dlx turbo login` then `pnpm dlx turbo link`, or paste token/team here.
# Do not commit real tokens; keep them in CI secrets or a local-only `.env.local`.
# -----------------------------------------------------------------------------
# TURBO_TOKEN=
# TURBO_TEAM=
# TURBO_CACHE_DIR=.artifacts/cache/turbo
